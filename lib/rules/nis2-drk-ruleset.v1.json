    },
    {
      "id": "SEC-12",
      "section": "security",
      "label": "Dokumentation: Richtlinienpaket + Nachweise vollständig auffindbar?",
      "type": "single_select",
      "options": [
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" },
        { "value": "yes", "label": "Ja" }
      ],
      "required": true
    }
  ],
  "rules": [
    {
      "id": "REG-J1",
      "description": "Ohne Rettungsdienst keine RD-getriebene Betroffenheit.",
      "when": [{ "questionId": "OPS-01", "op": "eq", "value": "no" }],
      "then": {
        "set": {
          "jurisdiction.isRdProvider": false,
          "jurisdiction.directlyRegulated": false,
          "jurisdiction.classification": "none",
          "outcome.type": "A"
        },
        "addRoadmapPacks": ["P7_DOC_AUDIT"]
      }
    },
    {
      "id": "REG-J2",
      "description": "Mit Rettungsdienst: Rechtsträgerlogik (ev vs subsidiary).",
      "when": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }],
      "then": {
        "set": {
          "jurisdiction.isRdProvider": true
        }
      }
    },
    {
      "id": "REG-J3-WICHTIG-VZA",
      "description": "Wichtige Einrichtung wenn VZÄ > 50.",
      "when": [
        { "questionId": "OPS-01", "op": "eq", "value": "yes" },
        { "questionId": "THR-01", "op": "gt", "value": 50 }
      ],
      "then": {
        "set": {
          "jurisdiction.directlyRegulated": true,
          "jurisdiction.classification": "important"
        },
        "addRoadmapPacks": ["P1_GOV_REG"]
      }
    },
    {
      "id": "REG-J3-BESONDERS-VZA",
      "description": "Besonders wichtige Einrichtung wenn VZÄ > 250.",
      "when": [
        { "questionId": "OPS-01", "op": "eq", "value": "yes" },
        { "questionId": "THR-01", "op": "gt", "value": 250 }
      ],
      "then": {
        "set": {
          "jurisdiction.directlyRegulated": true,
          "jurisdiction.classification": "especially_important"
        },
        "addRoadmapPacks": ["P1_GOV_REG"]
      }
    },
    {
      "id": "REG-J3-WICHTIG-FIN",
      "description": "Wichtige Einrichtung wenn Umsatz >10 Mio UND Bilanzsumme >10 Mio.",
      "when": [
        { "questionId": "OPS-01", "op": "eq", "value": "yes" },
        { "questionId": "THR-02", "op": "gt", "value": 10000000 },
        { "questionId": "THR-03", "op": "gt", "value": 10000000 }
      ],
      "then": {
        "set": {
          "jurisdiction.directlyRegulated": true,
          "jurisdiction.classification": "important"
        },
        "addRoadmapPacks": ["P1_GOV_REG"]
      }
    },
    {
      "id": "REG-J3-BESONDERS-FIN",
      "description": "Besonders wichtige Einrichtung wenn Umsatz >50 Mio UND Bilanzsumme >43 Mio.",
      "when": [
        { "questionId": "OPS-01", "op": "eq", "value": "yes" },
        { "questionId": "THR-02", "op": "gt", "value": 50000000 },
        { "questionId": "THR-03", "op": "gt", "value": 43000000 }
      ],
      "then": {
        "set": {
          "jurisdiction.directlyRegulated": true,
          "jurisdiction.classification": "especially_important"
        },
        "addRoadmapPacks": ["P1_GOV_REG"]
      }
    },
    {
      "id": "REG-J3-NOT",
      "description": "Wenn Schwellenwerte nicht erreicht: nicht direkt reguliert (RD vorhanden).",
      "when": [
        { "questionId": "OPS-01", "op": "eq", "value": "yes" },
        { "questionId": "THR-01", "op": "lte", "value": 50 },
        {
          "any": [
            { "questionId": "THR-02", "op": "lte_or_missing", "value": 10000000 },
            { "questionId": "THR-03", "op": "lte_or_missing", "value": 10000000 }
          ]
        }
      ],
      "then": {
        "set": {
          "jurisdiction.directlyRegulated": false,
          "jurisdiction.classification": "none"
        }
      }
    },
    {
      "id": "REG-T1-SHARED-IDENTITY",
      "description": "Shared Identity zieht technischen Scope hoch.",
      "when": [
        { "questionId": "OPS-01", "op": "eq", "value": "yes" },
        { "questionId": "IT-01", "op": "in", "value": ["yes", "partial"] }
      ],
      "then": {
        "set": { "scope.technical.sharedIdentity": true },
        "addRoadmapPacks": ["P2_IAM_ADMIN"]
      }
    },
    {
      "id": "REG-T2-SHARED-INFRA",
      "description": "Shared Infrastruktur zieht technischen Scope hoch.",
      "when": [
        { "questionId": "OPS-01", "op": "eq", "value": "yes" },
        {
          "any": [
            { "questionId": "IT-02", "op": "in", "value": ["yes", "partial"] },
            { "questionId": "IT-03", "op": "in", "value": ["yes", "partial"] },
            { "questionId": "IT-04", "op": "in", "value": ["yes", "partial"] }
          ]
        }
      ],
      "then": {
        "set": { "scope.technical.sharedInfrastructure": true },
        "addRoadmapPacks": ["P3_BACKUP_DR", "P4_NETWORK_SEG"]
      }
    },
    {
      "id": "REG-T3-SEPARATION-CHECK",
      "description": "Harte Trennung nur bei 8/8 Kriterien.",
      "when": [
        { "questionId": "OPS-01", "op": "eq", "value": "yes" }
      ],
      "then": {
        "compute": {
          "name": "scope.technical.hardSeparationPossible",
          "op": "allYes",
          "inputs": [
            "SEP-01",
            "SEP-02",
            "SEP-03",
            "SEP-04",
            "SEP-05",
            "SEP-06",
            "SEP-07",
            "SEP-08"
          ]
        }
      }
    },
    {
      "id": "REG-OUTCOME-A",
      "description": "Outcome A: kein RD oder nicht RD-getrieben.",
      "when": [{ "path": "jurisdiction.isRdProvider", "op": "eq", "value": false }],
      "then": {
        "set": {
          "outcome.type": "A",
          "outcome.label": "Nicht RD-getrieben betroffen",
          "outcome.summary": "Kein Rettungsdienst angegeben. RD-bezogene NIS-2/BSIG-Betroffenheit wird nicht ausgelöst."
        },
        "addRoadmapPacks": ["P7_DOC_AUDIT"]
      }
    },
    {
      "id": "REG-OUTCOME-D",
      "description": "Outcome D: unklare Datenlage (z.B. VZÄ fehlt) -> konservativ.",
      "when": [
        { "questionId": "OPS-01", "op": "eq", "value": "yes" },
        { "questionId": "THR-01", "op": "missing" }
      ],
      "then": {
        "set": {
          "outcome.type": "D",
          "outcome.label": "Unklar – konservativ behandeln",
          "outcome.summary": "Schwellenwerte sind nicht belastbar angegeben. VZÄ und Finanzdaten sind zu ermitteln."
        },
        "addRoadmapPacks": ["P1_GOV_REG", "P7_DOC_AUDIT"]
      }
    },
    {
      "id": "REG-OUTCOME-B",
      "description": "Outcome B: direkt betroffen, harte Trennung möglich -> Scope begrenzbar.",
      "when": [
        { "path": "jurisdiction.directlyRegulated", "op": "eq", "value": true },
        { "path": "scope.technical.hardSeparationPossible", "op": "eq", "value": true }
      ],
      "then": {
        "set": {
          "outcome.type": "B",
          "outcome.label": "Direkt betroffen – Scope begrenzbar",
          "outcome.summary": "Rettungsdienst ist direkt betroffen; eine harte technische Trennung ist nachgewiesen/erreichbar."
        },
        "addRoadmapPacks": ["P4_NETWORK_SEG", "P7_DOC_AUDIT", "P5_INCIDENT_REPORT"]
      }
    },
    {
      "id": "REG-OUTCOME-C",
      "description": "Outcome C: direkt betroffen + shared IT oder keine harte Trennung -> faktisch gruppenweit.",
      "when": [
        { "path": "jurisdiction.directlyRegulated", "op": "eq", "value": true },
        {
          "any": [
            { "path": "scope.technical.hardSeparationPossible", "op": "eq", "value": false },
            { "path": "scope.technical.sharedIdentity", "op": "eq", "value": true },
            { "path": "scope.technical.sharedInfrastructure", "op": "eq", "value": true }
          ]
        }
      ],
      "then": {
        "set": {
          "outcome.type": "C",
          "outcome.label": "Direkt betroffen – faktisch gruppenweiter technischer Scope",
          "outcome.summary": "Rettungsdienst ist direkt betroffen; aufgrund Shared-IT bzw. fehlender harter Trennung erstreckt sich der technische Scope auf zentrale/weitere IT-Bereiche."
        },
        "addRoadmapPacks": ["P2_IAM_ADMIN", "P3_BACKUP_DR", "P4_NETWORK_SEG", "P5_INCIDENT_REPORT", "P6_SUPPLY_CHAIN", "P7_DOC_AUDIT"]
      }
    }
  ],
  "scoring": {
    "model": "nis2_12_controls",
    "controls": [
