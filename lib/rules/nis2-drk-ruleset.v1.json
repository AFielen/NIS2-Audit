{
  "meta": {
    "id": "nis2-drk-standard-pack",
    "version": "1.0.0",
    "status": "active",
    "title": "NIS-2 Self-Audit – DRK Standard Pack (Single Ruleset)",
    "effectiveDate": "2026-03-03",
    "notes": [
      "Single ruleset: Rettungsdienst wird als potenziell BSIG/NIS-2-relevante Einrichtungsart behandelt, Betroffenheit hängt an Schwellenwerten.",
      "Keine Policy-Packs, kein Regelstand-Switch, keine Rückwärtskompatibilität erforderlich."
    ]
  },
  "enums": {
    "yesNoPartial": ["yes", "no", "partial"],
    "triState": ["no", "partial", "yes"],
    "segmentationLevel": ["none", "rudimentary", "clean"],
    "evidenceLevel": ["self", "document", "technical", "external_audit"],
    "orgModel": ["ev_only", "ev_plus_one_sub", "ev_plus_multi_sub", "mixed_other"],
    "entityType": ["ev", "ggmbh", "gmbh", "department_unselbst", "other"],
    "roadmapPack": [
      "P1_GOV_REG",
      "P2_IAM_ADMIN",
      "P3_BACKUP_DR",
      "P4_NETWORK_SEG",
      "P5_INCIDENT_REPORT",
      "P6_SUPPLY_CHAIN",
      "P7_DOC_AUDIT"
    ],
    "outcomeType": ["A", "B", "C", "D"]
  },
  "questions": [
    {
      "id": "ORG-01",
      "section": "org",
      "label": "Organisationsmodell",
      "type": "single_select",
      "options": [
        { "value": "ev_only", "label": "Alles im e.V. (Rettungsdienst als Abteilung möglich)" },
        { "value": "ev_plus_one_sub", "label": "e.V. + 1 Tochter (Rettungsdienst in gGmbH/GmbH)" },
        { "value": "ev_plus_multi_sub", "label": "e.V. + mehrere Töchter" },
        { "value": "mixed_other", "label": "Mischform / Sonstiges" }
      ],
      "required": true
    },
    {
      "id": "OPS-01",
      "section": "ops",
      "label": "Erbringt der Verbund rettungsdienstliche Leistungen (Notfallrettung / Rettungsdienst)?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" }
      ],
      "required": true
    },
    {
      "id": "ORG-03",
      "section": "org",
      "label": "Wo wird der Rettungsdienst betrieben?",
      "type": "single_select",
      "options": [
        { "value": "ev", "label": "Im e.V. (Abteilung)" },
        { "value": "subsidiary", "label": "In einer Beteiligungsgesellschaft (gGmbH/GmbH)" },
        { "value": "multiple", "label": "Auf mehrere Einheiten verteilt" }
      ],
      "required": true,
      "visibleIf": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }]
    },
    {
      "id": "THR-01",
      "section": "thresholds",
      "label": "Vollzeitäquivalente (VZÄ) des relevanten Rechtsträgers",
      "type": "number",
      "min": 0,
      "required": true,
      "visibleIf": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }]
    },
    {
      "id": "THR-02",
      "section": "thresholds",
      "label": "Jahresumsatz des relevanten Rechtsträgers (EUR)",
      "type": "number",
      "min": 0,
      "required": false,
      "visibleIf": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }]
    },
    {
      "id": "THR-03",
      "section": "thresholds",
      "label": "Jahresbilanzsumme des relevanten Rechtsträgers (EUR)",
      "type": "number",
      "min": 0,
      "required": false,
      "visibleIf": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }]
    },
    {
      "id": "IT-01",
      "section": "it",
      "label": "Gemeinsame Identitäten (AD/Entra ID/M365) für mehrere Einheiten?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" }
      ],
      "required": true
    },
    {
      "id": "IT-02",
      "section": "it",
      "label": "Gemeinsame Firewall/VPN/Standortnetz-Infrastruktur?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" }
      ],
      "required": true
    },
    {
      "id": "IT-03",
      "section": "it",
      "label": "Gemeinsames Backup-System für mehrere Einheiten?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" }
      ],
      "required": true
    },
    {
      "id": "IT-04",
      "section": "it",
      "label": "Gemeinsames Endpoint-/MDM-Management (z. B. Intune) über Einheiten hinweg?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" }
      ],
      "required": true
    },
    {
      "id": "IT-05",
      "section": "it",
      "label": "Segmentierung Rettungsdienst vs. restlicher Verbund",
      "type": "single_select",
      "options": [
        { "value": "none", "label": "Keine" },
        { "value": "rudimentary", "label": "Rudimentär (z.B. VLAN ohne harte Admin-/Identity-Trennung)" },
        { "value": "clean", "label": "Sauber (mit kontrollierten Übergängen und dokumentiert)" }
      ],
      "required": true
    },
    {
      "id": "SEP-01",
      "section": "separation",
      "label": "Getrennter Tenant/Domain für Rettungsdienst?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" }
      ],
      "required": true,
      "visibleIf": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }]
    },
    {
      "id": "SEP-02",
      "section": "separation",
      "label": "Getrennte privilegierte Admin-Accounts/Administration?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" }
      ],
      "required": true,
      "visibleIf": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }]
    },
    {
      "id": "SEP-03",
      "section": "separation",
      "label": "Getrennte Netzsegmente mit kontrollierten Übergängen?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" }
      ],
      "required": true,
      "visibleIf": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }]
    },
    {
      "id": "SEP-04",
      "section": "separation",
      "label": "Getrenntes Backup + Wiederherstellung getestet?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" }
      ],
      "required": true,
      "visibleIf": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }]
    },
    {
      "id": "SEP-05",
      "section": "separation",
      "label": "Getrenntes Endpoint-/MDM-Management?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" }
      ],
      "required": true,
      "visibleIf": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }]
    },
    {
      "id": "SEP-06",
      "section": "separation",
      "label": "Getrenntes Logging/Monitoring?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" }
      ],
      "required": true,
      "visibleIf": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }]
    },
    {
      "id": "SEP-07",
      "section": "separation",
      "label": "Getrennte Asset-Dokumentation (Inventar) für Rettungsdienst?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" }
      ],
      "required": true,
      "visibleIf": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }]
    },
    {
      "id": "SEP-08",
      "section": "separation",
      "label": "Nachweis: Vorfall im restlichen Verband beeinträchtigt Rettungsdienst nicht?",
      "type": "single_select",
      "options": [
        { "value": "yes", "label": "Ja" },
        { "value": "no", "label": "Nein" }
      ],
      "required": true,
      "visibleIf": [{ "questionId": "OPS-01", "op": "eq", "value": "yes" }]
    },
    {
      "id": "SEC-01",
      "section": "security",
      "label": "Governance: Verantwortliche Rolle (CISO/IT-Sicherheitsbeauftragter) benannt und dokumentiert?",
      "type": "single_select",
      "options": [
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" },
        { "value": "yes", "label": "Ja" }
      ],
      "required": true
    },
    {
      "id": "SEC-02",
      "section": "security",
      "label": "Management-Schulung zu NIS-2/BSIG durchgeführt und dokumentiert?",
      "type": "single_select",
      "options": [
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" },
        { "value": "yes", "label": "Ja" }
      ],
      "required": true
    },
    {
      "id": "SEC-03",
      "section": "security",
      "label": "Risikoanalyse für kritische Dienste/Systeme vorhanden?",
      "type": "single_select",
      "options": [
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" },
        { "value": "yes", "label": "Ja" }
      ],
      "required": true
    },
    {
      "id": "SEC-04",
      "section": "security",
      "label": "IAM/MFA: MFA für privilegierte Konten und Remote-Zugriffe vollständig?",
      "type": "single_select",
      "options": [
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" },
        { "value": "yes", "label": "Ja" }
      ],
      "required": true
    },
    {
      "id": "SEC-05",
      "section": "security",
      "label": "Privileged Access: Rollen-/Berechtigungskonzept (Admin-Trennung, Least Privilege) dokumentiert?",
      "type": "single_select",
      "options": [
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" },
        { "value": "yes", "label": "Ja" }
      ],
      "required": true
    },
    {
      "id": "SEC-06",
      "section": "security",
      "label": "Netzwerksegmentierung vorhanden und dokumentiert?",
      "type": "single_select",
      "options": [
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" },
        { "value": "yes", "label": "Ja" }
      ],
      "required": true
    },
    {
      "id": "SEC-07",
      "section": "security",
      "label": "Backup/Restore: Offline-Backups + Wiederherstellung getestet?",
      "type": "single_select",
      "options": [
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" },
        { "value": "yes", "label": "Ja" }
      ],
      "required": true
    },
    {
      "id": "SEC-08",
      "section": "security",
      "label": "Logging/Monitoring: Zentrale Logs, Alarmierung, Auswertung etabliert?",
      "type": "single_select",
      "options": [
        { "value": "no", "label": "Nein" },
