    },
    {
      "id": "SEC-11",
      "section": "security",
      "label": "Lieferkette: IT-Dienstleister/Cloud bewertet und vertraglich abgesichert?",
      "type": "single_select",
      "options": [
        { "value": "no", "label": "Nein" },
        { "value": "partial", "label": "Teilweise" },
        { "value": "yes", "label": "Ja" }
      ],
